export NUM_ENVS="4096"
export NUM_STEPS="64"
export TOTAL_TIMESTEPS="500000000"
export N_DEVICES="4"
export SEED="42"
export TIMING="True"

export WANDB_MODE="online"
export WANDB_ENTITY="${WANDB_ENTITY_DEFAULT:-ark-dong-university-of-amsterdam}"
export WANDB_PROJECT="Thesis-mm-risk-neutral"