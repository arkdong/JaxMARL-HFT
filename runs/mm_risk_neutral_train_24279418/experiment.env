# Risk-neutral MM training only. No baseline eval, no rho_star estimate.

export EXP_NAME="mm_risk_neutral_train"
export STOCK="AMZN"
export PERIOD="train"

export JOB_NAME="jmhft-mm-rn"
export PARTITION="gpu_h100"
export NODES="1"
export NTASKS="1"
export CPUS_PER_TASK="64"
export GPUS="4"
export MEM="720G"
export WALLTIME="12:00:00"

export TRAIN_SCRIPT="gymnax_exchange/jaxrl/MARL/ippo_rnn_JAXMARL.py"
