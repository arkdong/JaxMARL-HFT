# Experiment-specific settings for the AS classical-control baseline.
# Submit with:
#   bash snellius_scripts/submit_as_baseline.sh snellius_scripts/experiments/as_lobster_baseline.env

# Research/data identity
export EXP_NAME="as_lobster_amzn_finite"
export STOCK="AMZN"

# Slurm resources. AS is CPU/memory heavy; start conservative and increase
# AS_WORKERS only after checking memory usage on your data.
export JOB_NAME="as-amzn-finite"
export PARTITION="cbuild"
export NODES="1"
export NTASKS="1"
export CPUS_PER_TASK="32"
export GPUS="0"
export MEM="240G"
export WALLTIME="12:00:00"

# AS data and outputs
export AS_DATA_FORMAT="lobster"
export AS_DATA_DIR="${DATA_ROOT}/rawLOBSTER/${STOCK}"
export AS_CACHE_DIR="${CACHE_ROOT}/as_lobster_10"
export AS_OUTPUT_DIR=""              # empty => ${RUN_DIR}/results/AS
export AS_BASELINES_OUTPUT_DIR=""    # empty => ${RUN_DIR}/results/baselines
export AS_RESUME_FROM_CALIBRATION="" # set to a compatible as_calibration.json to skip train calibration

# AS baseline settings
export AS_HORIZON_MODE="finite_episode"
export AS_WORKERS="1"
export AS_LOBSTER_LEVELS="10"
export AS_ORDER_SIZE="10"
export AS_INVENTORY_LIMIT="200"
export AS_DECISION_INTERVAL_MS="250"
export AS_EPISODE_STEPS="64"
export AS_TICK_SIZE="0.01"
export AS_Q_REF="20.0"
export AS_TARGET_SKEW="0.05"
export AS_DELTA_START_TICKS="1"
export AS_DELTA_END_TICKS="20"
export AS_GAMMA_VALUES=""            # optional comma list, e.g. calibrated=0.037
export AS_EPISODE_STARTS_CSV=""      # optional manifest
export AS_INCLUDE_SYMMETRIC="false"
export AS_NO_PLOTS="true"
export AS_DEBUG_PLOTS="false"
export AS_RUN_TESTS="false"
