# Smoke validation settings for the frozen old-checkpoint rho_ex reference eval.
# Submit with:
#   bash snellius_scripts/submit_eval.sh snellius_scripts/eval/rho_ex_reference_validation_smoke.env

export EXP_NAME="rho_ex_reference_validation_smoke"
export STOCK="AMZN"
export PERIOD="val"

export JOB_NAME="rho-ex-ref-smoke"
export PARTITION="gpu_h100"
export NODES="1"
export NTASKS="1"
export CPUS_PER_TASK="16"
export GPUS="${GPUS:-1}"
export MEM="120G"
export WALLTIME="00:20:00"

export EVAL_SCRIPT="gymnax_exchange/jaxrl/MARL/eval_checkpoint_rho_ex_reference.py"
export CONFIG_NAME="eval_old_checkpoint_rho_ex_reference"
export ENV_CONFIG="config/env_configs/2_player_fq_fqc_old_checkpoint_validation_v3.json"

export NUM_ENVS="64"
export NUM_STEPS="64"
export NUM_UPDATES="1"
export N_DEVICES="1"
export SEED="42"
export GRU_HIDDEN_DIM="256"
export FC_DIM_SIZE="256"

export RESTORE_PROJECT="Thesis-mm-risk-neutral"
export RESTORE_RUN="colorful-sweep-1"
export RESTORE_STEP="latest"

export OUTPUT_DIR=""

export WANDB_MODE="disabled"
export WANDB_ENTITY="${WANDB_ENTITY_DEFAULT:-ark-dong-university-of-amsterdam}"
export WANDB_PROJECT="Thesis-rho-ex-reference"
