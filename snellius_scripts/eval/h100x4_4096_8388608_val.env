# Validation settings for the Thesis 32-update AMZN checkpoint.
# This restores a trained policy and evaluates it on held-out validation data.

# Research/data identity
export EXP_NAME="small_val"
export STOCK="AMZN"
export PERIOD="val"

# Slurm resources
export JOB_NAME="jmhft-small-val"
export PARTITION="gpu_h100"
export NODES="1"
export NTASKS="1"
export CPUS_PER_TASK="64"
export GPUS="1"
export MEM="240G"
export WALLTIME="01:00:00"

# Evaluation command
export EVAL_SCRIPT="gymnax_exchange/jaxrl/MARL/baseline_eval/baseline_JAXMARL.py"
export CONFIG_NAME="2player_config"
export ENV_CONFIG="config/env_configs/2_player_fq_fqc.json"
export NUM_ENVS="4096"
export NUM_STEPS="64"
export NUM_UPDATES="32"
export N_DEVICES="1"
export SEED="42"
export GRU_HIDDEN_DIM="256"
export FC_DIM_SIZE="256"

# Restore trained model
export RESTORE_PROJECT="Thesis"
export RESTORE_RUN="ethereal-sweep-1"
export RESTORE_STEP="32"

# Logging
export WANDB_MODE="online"
export WANDB_ENTITY="${WANDB_ENTITY_DEFAULT:-ark-dong-university-of-amsterdam}"
export WANDB_PROJECT="Thesis-validation"
